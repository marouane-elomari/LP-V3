{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Blog articles for the Luuzon landing page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true,
      "maxLength": 500
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "author_name": {
      "type": "string",
      "maxLength": 100
    },
    "meta_title": {
      "type": "string",
      "maxLength": 70
    },
    "meta_description": {
      "type": "string",
      "maxLength": 160
    },
    "meta_keywords": {
      "type": "string",
      "maxLength": 255
    },
    "locale": {
      "type": "string",
      "default": "fr",
      "enum": ["fr", "en"]
    }
  }
}
